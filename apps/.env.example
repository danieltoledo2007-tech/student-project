# Template for local environment config.
# Copy this file to apps/.env (which is git-ignored) and adjust the values:
#   cp apps/.env.example apps/.env
#
# Port the NestJS API listens on (default: 3000).
# If you change it, update apps/*/proxy.conf.json to point at the same port.
PORT=3000

# Host the API binds to (currently informational — the server listens on all interfaces).
HOST=localhost

# MongoDB connection string. The path segment at the end is the database name.
MONGO_URI=mongodb://localhost:27017/student-project

# Which tasks storage implementation to use: "mongo" (default) or "file".
# Swapping the value swaps the whole storage layer — see tasks.module.ts.
STORAGE=mongo
