{
  "name": "student-api-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": ["student-api"],
  "projectType": "application",
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/student-api-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["student-api:build", "student-api:serve"]
    }
  }
}
